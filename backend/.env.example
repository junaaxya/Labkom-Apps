# Backend Environment Variables
DATABASE_URL=postgresql://postgres:password@localhost:5432/lab_management?schema=public
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000
REDIS_URL=redis://localhost:6379
# Local dev default is ./uploads. Set explicit host/container path in production.
UPLOAD_DIR=./uploads

# Optional integrations
OPENAI_API_KEY=your-openai-api-key
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/calendar/callback

# Duitku payment gateway for public hosting service checkout
DUITKU_MERCHANT_CODE=your-duitku-merchant-code
DUITKU_API_KEY=your-duitku-api-key
DUITKU_IS_PRODUCTION=false
DUITKU_CALLBACK_URL=https://your-backend-domain.example.com/api/v1/hosting/callback
HOSTING_BRAND_NAME=LabKom Hosting

# Native PWA Web Push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@labkom.ac.id

# WhatsApp Bot (optional)
ENABLE_WHATSAPP=false

# Development
NODE_ENV=development
PORT=5000

# Wake-on-LAN relay from production host.
# Preferred production setup: backend calls a loopback-only host relay HTTP service.
WOL_RELAY_URL=
WOL_RELAY_TOKEN=
# Legacy fallback for environments that still execute a local helper command.
# The command receives: <macAddress> <broadcastAddress>
# Example wrapper on server: /usr/local/bin/labkom-wol
WOL_HOST_COMMAND=
WOL_DEFAULT_BROADCAST=192.168.100.255
